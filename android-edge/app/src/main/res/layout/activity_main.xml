<?xml version="1.0" encoding="utf-8"?>
<!-- Phase 1 test layout: single-screen voice session launcher -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AURA"
        android:textColor="#E0E0E0"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice-Native OS Controller"
        android:textColor="#808080"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Status badge -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IDLE"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        android:background="@drawable/status_badge_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toBottomOf="@id/subtitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Pulsing mic indicator -->
    <View
        android:id="@+id/pulseIndicator"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/pulse_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Start / Stop button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/toggleButton"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="Start Session"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        app:backgroundTint="#1DB954"
        app:layout_constraintBottom_toTopOf="@id/logScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

    <!-- Live log output -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="#1A1A1A"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready to connect...\n"
            android:textColor="#4CAF50"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
